rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      let c = get(/databases/$(database)/documents/couples/$(coupleId)).data;
      return c.user1 == request.auth.uid || c.user2 == request.auth.uid;
    }

    match /users/{userId} {
      // Profiles are readable by any signed-in user (needed to show the
      // partner's name); only the owner can write their own doc, except
      // the pairing flow which sets partnerId on the inviter's doc.
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerId'])
      );
    }

    match /couples/{coupleId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user1 == request.auth.uid;
      // Members can update; a non-member may only claim the empty user2
      // slot (joining with an invite code).
      allow update: if signedIn() && (
        resource.data.user1 == request.auth.uid ||
        resource.data.user2 == request.auth.uid ||
        (resource.data.user2 == null &&
          request.resource.data.user2 == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user2']))
      );
    }

    match /wishlistItems/{itemId} {
      allow read, update, delete: if signedIn() && isCoupleMember(resource.data.coupleId);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isCoupleMember(request.resource.data.coupleId);
    }

    // Secret plans: strictly private to the planner. The wish's creator
    // has no way to read these, which is what keeps surprises secret.
    match /plans/{planId} {
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && planId == request.resource.data.wishId + '_' + request.auth.uid
        && isCoupleMember(request.resource.data.coupleId);
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if signedIn();
    }
  }
}
